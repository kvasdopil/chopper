    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "clsx": "^2.1.1",
    "jscpd": "^4.0.5",
    "knip": "^5.66.3",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tailwind-merge": "^3.4.0",
